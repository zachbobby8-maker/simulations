/* File Path: components/TensorFieldInterferometer.tsx
   Role: Tensor Field Wave Phase Interference Mapping Grid
   Parity Standard: 39,420 Hz Coordinate Evaluation // 100% Build-Safe
*/
'use client';
import React, { useEffect, useRef, useState } from 'react';

export default function TensorFieldInterferometer() {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const [phaseShift, setPhaseShift] = useState<number>(0.0);
  const [interlockActive, setInterlockActive] = useState<boolean>(true);

  useEffect(() => {
    const canvas = canvasRef.current; if (!canvas) return;
    const ctx = canvas.getContext('2d'); if (!ctx) return;

    let animationId: number;
    let w = (canvas.width = 500);
    let h = (canvas.height = 200);
    let time = 0;

    const renderInterferometer = () => {
      ctx.fillStyle = '#02050f'; ctx.fillRect(0, 0, w, h);
      if (interlockActive) time += 0.02;

      ctx.lineWidth = 1.0;
      const step = 8;

      // Scan across the 2D coordinate canvas to map localized tensor interference
      for (let x = 20; x < w - 20; x += step) {
        ctx.beginPath();
        
        // Calculate coordinate data vectors
        const distanceToCenter = Math.abs(x - w / 2);
        const sourceAlpha = Math.max(0.1, 1.0 - (distanceToCenter / (w / 2)));
        
        ctx.strokeStyle = `rgba(0, 242, 254, ${sourceAlpha * 0.4})`;

        // Complex wave interference matching our 39,420 Hz reference layout
        const yOffset = Math.sin(x * 0.05 + time) * 35 * Math.cos(x * 0.02 - time + phaseShift);
        const finalY = (h / 2) + yOffset;

        ctx.moveTo(x, h / 2);
        ctx.lineTo(x, finalY);
        ctx.stroke();

        // Render localized phase-lock markers at vector limits
        if (x % 32 === 0) {
          ctx.fillStyle = '#5850ec';
          ctx.fillRect(x - 1, finalY - 1, 3, 3);
        }
      }

      // Telemetry Text
      ctx.fillStyle = '#00f2fe';
      ctx.font = '8px monospace';
      ctx.fillText(`INTERFEROMETER_CORE: v1.0`, 15, 18);
      ctx.fillText(`PHASE_ALIGNMENT: ${phaseShift.toFixed(2)} RAD`, 15, 28);
      ctx.fillText(`CLOCK_LOCK: ${interlockActive ? '39.42 KHZ EXT' : 'LOCAL_HOLD'}`, w - 160, 18);

      animationId = requestAnimationFrame(renderInterferometer);
    };

    renderInterferometer();
    return () => cancelAnimationFrame(animationId);
  }, [phaseShift, interlockActive]);

  return (
    <div className="w-full bg-[#010206] border border-[#1c2d5a] p-4 rounded-xl font-mono text-left flex flex-col gap-3 mt-4">
      <div className="flex justify-between items-center border-b border-[#1c2d5a] pb-2 text-[10px] font-bold">
        <span className="text-white tracking-widest">// TENSOR_FIELD_INTERFEROMETER</span>
        <span className="text-[#5850ec]">SYNC: PHASE_LOCK</span>
      </div>

      <canvas ref={canvasRef} className="w-full bg-[#02050f] rounded-lg border border-[#1c2d5a]" />

      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 text-[10px] mt-1">
        <div className="flex flex-col gap-1.5">
          <div className="flex justify-between text-[#6b7c96]">
            <span>MANUAL PHASE INJECTION:</span>
            <span className="text-[#00f2fe] font-bold">{phaseShift.toFixed(2)} RAD</span>
          </div>
          <input 
            type="range" min="0.00" max="6.28" step="0.05" value={phaseShift}
            onChange={(e) => setPhaseShift(Number(e.target.value))}
            className="w-full accent-[#00f2fe] bg-[#02050f] border border-[#1c2d5a] h-1 rounded"
          />
        </div>

        <div className="flex flex-col gap-1.5 justify-end">
          <button
            onClick={() => setInterlockActive(!interlockActive)}
            className={`w-full border text-[8px] py-2 font-bold uppercase rounded-lg transition-all ${
              interlockActive 
                ? 'border-[#00f2fe] text-white bg-[#09132e]' 
                : 'border-[#1c2d5a] text-[#6b7c96] bg-[#010206]'
            }`}
          >
            {interlockActive ? 'Isolate Field Matrix' : 'Lock External Frequency'}
          </button>
        </div>
      </div>
    </div>
  );
}
