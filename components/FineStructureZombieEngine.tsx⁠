/* File Path: components/FineStructureZombieEngine.tsx
   Role: Fine Structure Constant Vector & Outbreak Drift Grid Simulator
   Parity Standard: 39,420 Hz Phase-Locked Containment Perimeter
*/
'use client';
import React, { useEffect, useRef, useState } from 'react';

export default function FineStructureZombieEngine() {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const [alphaState, setAlphaState] = useState<string>('stable'); // stable (1/137) vs drifted (1/120)
  const [gridIntegrity, setGridIntegrity] = useState<number>(100.00);

  useEffect(() => {
    const canvas = canvasRef.current; if (!canvas) return;
    const ctx = canvas.getContext('2d'); if (!ctx) return;

    let animationId: number;
    let w = (canvas.width = 500);
    let h = (canvas.height = 240);

    // Particle pool tracking anomalous zombie vectors inside the perimeter
    const particleCount = 42;
    const nodes: { x: number; y: number; vx: number; vy: number; status: string }[] = [];

    for (let i = 0; i < particleCount; i++) {
      nodes.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 1.2,
        vy: (Math.random() - 0.5) * 1.2,
        status: Math.random() > 0.85 ? 'anomalous' : 'contained'
      });
    }

    const renderGrid = () => {
      ctx.fillStyle = '#02050f'; ctx.fillRect(0, 0, w, h);

      // Set speed scale factor based on Fine Structure atomic stability variables
      const velocityMultiplier = alphaState === 'stable' ? 1.0 : 2.8;
      const alphaConstantText = alphaState === 'stable' ? 'α = 1/137.036' : 'α = 1/120.000 [CRITICAL]';

      // Render containment grid background rules
      ctx.strokeStyle = alphaState === 'stable' ? 'rgba(0, 242, 254, 0.08)' : 'rgba(239, 68, 68, 0.15)';
      ctx.lineWidth = 0.5;
      const gridSpacing = 20;
      for (let x = 0; x < w; x += gridSpacing) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke();
      }
      for (let y = 0; y < h; y += gridSpacing) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
      }

      // Update and project node trajectories
      nodes.forEach((node, index) => {
        node.x += node.vx * velocityMultiplier;
        node.y += node.vy * velocityMultiplier;

        // Perfect boundary inversion shunts
        if (node.x < 0 || node.x > w) node.vx *= -1;
        if (node.y < 0 || node.y > h) node.vy *= -1;

        // Render point clusters
        ctx.fillStyle = node.status === 'anomalous' ? '#ef4444' : '#00f2fe';
        if (alphaState === 'drifted') ctx.fillStyle = '#ef4444'; // Total breach coloration override

        ctx.beginPath();
        ctx.arc(node.x, node.y, node.status === 'anomalous' ? 3.5 : 2.0, 0, Math.PI * 2);
        ctx.fill();

        // Dynamically link proximity proximity lines to draw the vector grid mesh
        for (let j = index + 1; j < nodes.length; j++) {
          const nextNode = nodes[j];
          const dist = Math.hypot(node.x - nextNode.x, node.y - nextNode.y);

          if (dist < 60) {
            ctx.strokeStyle = alphaState === 'stable' 
              ? `rgba(0, 242, 254, ${1 - dist / 60})` 
              : `rgba(239, 68, 68, ${1 - dist / 60})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(node.x, node.y);
            ctx.lineTo(nextNode.x, nextNode.y);
            ctx.stroke();
          }
        }
      });

      // Render text telemetry inside canvas border bounds
      ctx.fillStyle = alphaState === 'stable' ? '#00f2fe' : '#ef4444';
      ctx.font = '9px monospace';
      ctx.fillText(`CONTAINMENT_CONSTANT: ${alphaConstantText}`, 15, h - 20);
      ctx.fillText(`GRID_COHERENCE_RATE: ${gridIntegrity.toFixed(2)}%`, 15, h - 35);

      // Systemic leak processing simulation state changes
      if (alphaState === 'drifted' && gridIntegrity > 14.62) {
        setGridIntegrity(prev => Math.max(14.62, prev - 0.09));
      } else if (alphaState === 'stable' && gridIntegrity < 100) {
        setGridIntegrity(prev => Math.min(100, prev + 0.42));
      }

      animationId = requestAnimationFrame(renderGrid);
    };

    renderGrid();
    return () => cancelAnimationFrame(animationId);
  }, [alphaState, gridIntegrity]);

  return (
    <div className="w-full bg-[#010206] border border-[#1c2d5a] p-4 rounded-xl font-mono text-left flex flex-col gap-3">
      <div className="flex justify-between items-center border-b border-[#1c2d5a] pb-2 text-[10px] font-bold">
        <span className="text-white tracking-widest">// FINE_STRUCTURE_ZOMBIE_CONTAINMENT_GRID</span>
        <span className={`text-[9px] px-1.5 py-0.5 rounded border ${
          alphaState === 'stable' ? 'border-[#00f2fe] text-[#00f2fe] bg-[#09132e]' : 'border-[#ef4444] text-[#ef4444] bg-red-950/20'
        }`}>
          STATUS: {alphaState === 'stable' ? 'SECURE_1/137' : 'DRIFT_BREACH'}
        </span>
      </div>

      <canvas ref={canvasRef} className="w-full bg-[#02050f] rounded-lg border border-[#1c2d5a]" />

      <div className="grid grid-cols-2 gap-2 mt-1">
        <button
          onClick={() => setAlphaState('stable')}
          className={`text-[9px] py-2 uppercase font-bold tracking-wider rounded border transition-all ${
            alphaState === 'stable'
              ? 'border-[#00f2fe] text-white bg-[#09132e]'
              : 'border-[#1c2d5a] text-[#6b7c96] bg-[#02050f] hover:border-[#5850ec]'
          }`}
        >
          Initialize 1/137 Constant
        </button>
        <button
          onClick={() => setAlphaState('drifted')}
          className={`text-[9px] py-2 uppercase font-bold tracking-wider rounded border transition-all ${
            alphaState === 'drifted'
              ? 'border-[#ef4444] text-white bg-red-950/20'
              : 'border-[#1c2d5a] text-[#6b7c96] bg-[#02050f] hover:border-red-900'
          }`}
        >
          Simulate Outbreak Drift
        </button>
      </div>
    </div>
  );
}
